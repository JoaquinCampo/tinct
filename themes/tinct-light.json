    "notificationLink.foreground": "#3366BB",
    "notificationsErrorIcon.foreground": "#C04040",
    "notificationsWarningIcon.foreground": "#A06B10",
    "notificationsInfoIcon.foreground": "#1A7D99",

    "editorWidget.background": "#F2F4FA",
