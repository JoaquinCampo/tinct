    "textLink.activeForeground": "#2E5BAA",
    "textBlockQuote.background": "#F0F2F8",
    "textBlockQuote.border": "#D0D8E8",
    "textCodeBlock.background": "#F0F2F8",

    "focusBorder": "#3366BB80",
    "foreground": "#2E3440",
    "descriptionForeground": "#6070A0",
    "errorForeground": "#C04040",
