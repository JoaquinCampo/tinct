    "terminal.ansiBrightMagenta": "#8E55BF",
    "terminal.ansiBrightCyan": "#2490B0",
    "terminal.ansiBrightWhite": "#FAFBFE",
    "terminalCursor.foreground": "#3366BB",

    "input.background": "#FFFFFF",
