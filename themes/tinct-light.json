    "button.secondaryHoverBackground": "#D0D8E8",

    "badge.background": "#3366BB",
    "badge.foreground": "#FFFFFF",

    "scrollbar.shadow": "#00000010",
    "scrollbarSlider.background": "#C0C8D840",
    "scrollbarSlider.hoverBackground": "#A0A8B860",
    "scrollbarSlider.activeBackground": "#8090A880",

    "minimap.background": "#FAFBFE",
    "minimap.selectionHighlight": "#D8DEF0",
    "minimap.findMatchHighlight": "#E8D090",
    "minimapGutter.addedBackground": "#3A7A2A",
    "minimapGutter.modifiedBackground": "#2E5BAA",
    "minimapGutter.deletedBackground": "#C04040",

    "gitDecoration.addedResourceForeground": "#3A7A2A",
    "gitDecoration.modifiedResourceForeground": "#2E5BAA",
    "gitDecoration.deletedResourceForeground": "#C04040",
    "gitDecoration.untrackedResourceForeground": "#3A7A2A",
    "gitDecoration.ignoredResourceForeground": "#B0B8C8",
    "gitDecoration.conflictingResourceForeground": "#A06B10",
    "gitDecoration.stageModifiedResourceForeground": "#2E5BAA",
    "gitDecoration.stageDeletedResourceForeground": "#C04040",
    "gitDecoration.submoduleResourceForeground": "#1A7D99",

    "breadcrumb.foreground": "#8890A8",
    "breadcrumb.focusForeground": "#2E3440",
    "breadcrumb.activeSelectionForeground": "#2E3440",
    "breadcrumbPicker.background": "#F2F4FA",

    "peekView.border": "#3366BB",
    "peekViewEditor.background": "#F2F4FA",
    "peekViewEditor.matchHighlightBackground": "#E8D09060",
    "peekViewResult.background": "#ECEEF6",
    "peekViewResult.fileForeground": "#2E3440",
    "peekViewResult.lineForeground": "#5060A0",
    "peekViewResult.matchHighlightBackground": "#E8D09060",
    "peekViewResult.selectionBackground": "#D8DEF0",
    "peekViewResult.selectionForeground": "#2E3440",
    "peekViewTitle.background": "#ECEEF6",
    "peekViewTitleDescription.foreground": "#8890A8",
    "peekViewTitleLabel.foreground": "#2E3440",

    "notification.background": "#F2F4FA",
    "notification.foreground": "#2E3440",
