    "diffEditor.insertedTextBackground": "#3A7A2A15",
    "diffEditor.removedTextBackground": "#C0404015",
    "diffEditor.diagonalFill": "#E0E4F0",

    "merge.currentHeaderBackground": "#3A7A2A30",
    "merge.currentContentBackground": "#3A7A2A15",
    "merge.incomingHeaderBackground": "#2E5BAA30",
    "merge.incomingContentBackground": "#2E5BAA15"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.line.number-sign.python"
      ],
      "settings": {
        "foreground": "#9098A8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Docstrings",
      "scope": [
        "string.quoted.docstring",
        "string.quoted.docstring.multi.python"
      ],
      "settings": {
        "foreground": "#7880A0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template"
      ],
      "settings": {
        "foreground": "#3A7A2A"
      }
    },
    {
      "name": "String escape sequences",
      "scope": [
        "constant.character.escape",
        "constant.character.escape.python"
      ],
      "settings": {
        "foreground": "#1A7A6A"
      }
    },
    {
      "name": "F-string braces",
      "scope": [
        "constant.character.format.placeholder.other.python",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#A06B10"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal",
        "constant.numeric.binary"
      ],
      "settings": {
        "foreground": "#1A7A6A"
      }
    },
    {
      "name": "Built-in constants (True, False, None)",
      "scope": [
        "constant.language",
        "constant.language.python"
      ],
      "settings": {
        "foreground": "#3A7A2A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Structure keywords — def, class, lambda",
      "scope": [
        "storage.type.function.python",
        "storage.type.class.python",
        "keyword.operator.unpacking.python",
        "storage.type.function.lambda.python"
      ],
      "settings": {
        "foreground": "#2E5BAA",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Import keywords",
      "scope": [
        "keyword.control.import.python",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#3968B8"
      }
    },
    {
      "name": "Flow control — if, elif, else, for, while, with, assert",
      "scope": [
        "keyword.control.flow.python",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#A06B10"
      }
    },
    {
      "name": "Return and yield",
      "scope": [
        "keyword.control.flow.return.python",
        "keyword.control.flow.yield.python"
      ],
      "settings": {
        "foreground": "#B87A18",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Exception handling — try, except, finally, raise",
      "scope": [
        "keyword.control.exception.python",
        "keyword.control.flow.raise.python",
        "keyword.control.flow.try.python",
        "keyword.control.flow.except.python",
        "keyword.control.flow.finally.python"
      ],
      "settings": {
        "foreground": "#8A5A08"
      }
    },
    {
      "name": "Minor flow — break, continue, pass",
      "scope": [
        "keyword.control.flow.break.python",
        "keyword.control.flow.continue.python",
        "keyword.control.flow.pass.python"
      ],
      "settings": {
        "foreground": "#9A7030"
      }
    },
    {
      "name": "Logical operators — and, or, not",
      "scope": [
        "keyword.operator.logical",
        "keyword.operator.logical.python"
      ],
      "settings": {
        "foreground": "#7B42AC"
      }
    },
    {
      "name": "Comparison and identity operators",
      "scope": [
        "keyword.operator.comparison",
        "keyword.operator.comparison.python"
      ],
      "settings": {
        "foreground": "#7B42AC"
      }
    },
    {
      "name": "Arithmetic operators",
      "scope": [
        "keyword.operator.arithmetic",
        "keyword.operator.arithmetic.python"
      ],
      "settings": {
        "foreground": "#6068A0"
      }
    },
    {
      "name": "Assignment operators",
      "scope": [
        "keyword.operator.assignment",
        "keyword.operator.assignment.python"
      ],
      "settings": {
        "foreground": "#7080A0"
      }
    },
    {
      "name": "Other operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.python"
      ],
      "settings": {
        "foreground": "#6068A0"
      }
    },
    {
      "name": "Function definition name",
      "scope": [
        "entity.name.function.python",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#1A4FA0"
      }
    },
    {
      "name": "Class definition name",
      "scope": [
        "entity.name.type.class.python",
        "entity.name.type.class"
      ],
      "settings": {
        "foreground": "#1A4FA0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorator",
      "scope": [
        "entity.name.function.decorator.python",
        "punctuation.definition.decorator.python",
        "meta.decorator.python"
      ],
      "settings": {
        "foreground": "#A86030",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function calls",
      "scope": [
        "meta.function-call.generic.python",
        "meta.function-call.python variable.function"
      ],
      "settings": {
        "foreground": "#1A7D99"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function.builtin.python",
        "support.function"
      ],
      "settings": {
        "foreground": "#0E6E8A"
      }
    },
    {
      "name": "Built-in types",
      "scope": [
        "support.type.python",
        "support.type"
      ],
      "settings": {
        "foreground": "#0E6E8A"
      }
    },
    {
      "name": "Self and cls",
      "scope": [
        "variable.parameter.function.language.special.self.python",
        "variable.parameter.function.language.special.cls.python",
        "variable.language.special.self.python",
        "variable.language.special.cls.python"
      ],
      "settings": {
        "foreground": "#8890A8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter.function.python",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#2E3440"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#2E3440"
      }
    },
    {
      "name": "Attribute access",
      "scope": [
        "variable.other.property",
        "meta.attribute.python"
      ],
      "settings": {
        "foreground": "#4A5A70"
      }
    },
    {
      "name": "Type hints",
      "scope": [
        "meta.function.parameters.python support.type",
        "meta.function.parameters.python meta.type.python",
        "meta.return-type.python support.type",
        "meta.function.return-type.python",
        "meta.function.python meta.type.annotation"
      ],
      "settings": {
        "foreground": "#5868A0"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.section",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#B0B8C8"
      }
    },
    {
      "name": "Punctuation — brackets and parens",
      "scope": [
        "punctuation.definition.list.begin.python",
        "punctuation.definition.list.end.python",
        "punctuation.definition.dict.begin.python",
        "punctuation.definition.dict.end.python",
        "punctuation.parenthesis.begin.python",
        "punctuation.parenthesis.end.python"
      ],
      "settings": {
        "foreground": "#8890A8"
      }
    },
    {
      "name": "String punctuation",
      "scope": [
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#3A7A2A"
      }
    },

    {
      "name": "Generic — Storage keywords",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#2E5BAA"
      }
    },
    {
      "name": "Generic — Keywords",
      "scope": [
        "keyword",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#A06B10"
      }
    },
    {
      "name": "Generic — Entity names",
      "scope": [
        "entity.name",
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#2E5BAA"
      }
    },
    {
      "name": "Generic — Entity attributes (HTML/XML)",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#A06B10",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Generic — Inherited class",
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#1A7D99",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Generic — Library/framework",
      "scope": [
        "support.class",
        "support.module",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#0E6E8A"
      }
    },
    {
      "name": "Generic — Constants",
      "scope": [
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#1A7A6A"
      }
    },
    {
      "name": "Generic — Regex",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp",
        "keyword.operator.quantifier.regexp"
      ],
      "settings": {
        "foreground": "#7B42AC"
      }
    },
    {
      "name": "Generic — Markup heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#2E5BAA",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Generic — Markup bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#2E3440",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Generic — Markup italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#2E3440",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Generic — Markup code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#3A7A2A"
      }
    },
    {
      "name": "Generic — Markup link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#1A7D99"
      }
    },
    {
      "name": "Generic — Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#3A7A2A"
      }
    },
    {
      "name": "Generic — Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#C04040"
      }
    },
    {
      "name": "Generic — Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#A06B10"
      }
    },
    {
      "name": "JSON — Property keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#2E5BAA"
      }
    },
    {
      "name": "YAML — Keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#2E5BAA"
      }
    },
