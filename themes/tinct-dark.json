    "editorWidget.resizeBorder": "#3A3F5C",
    "editorSuggestWidget.background": "#1A1D32",
    "editorSuggestWidget.border": "#2E3250",
    "editorSuggestWidget.selectedBackground": "#2E3250",
    "editorSuggestWidget.highlightForeground": "#7AA2F0",
    "editorHoverWidget.background": "#1A1D32",
    "editorHoverWidget.border": "#2E3250",
    "editorGroupHeader.tabsBackground": "#141626",
    "editorGroupHeader.tabsBorder": "#181A2E",
    "editorGroup.border": "#2E3250",

    "tab.activeBackground": "#181A2E",
    "tab.activeForeground": "#C5CADA",
    "tab.activeBorderTop": "#7AA2F0",
    "tab.inactiveBackground": "#141626",
    "tab.inactiveForeground": "#606880",
