    "editor.rangeHighlightBackground": "#1E213880",
    "editor.wordHighlightBackground": "#7AA2F022",
    "editor.wordHighlightStrongBackground": "#7AA2F033",
    "editorCursor.foreground": "#7AA2F0",
    "editorLineNumber.foreground": "#3A3F5C",
